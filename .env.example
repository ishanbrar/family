# Public site URL for Open Graph, Twitter cards, and absolute links in metadata.
# Set the same variable in Vercel → Project → Settings → Environment Variables.
NEXT_PUBLIC_APP_URL=https://legatree.us

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional fallback for admin auth operations if database RPCs are not deployed yet.
# Prefer applying supabase/migrations/20260527200000_family_admin_user_management.sql instead.
# Find this in Supabase Dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=
